# =============================================================================
# Kadryza Monorepo — Global .gitignore
# =============================================================================

# ─── Go (Backend) ────────────────────────────────────────────────────
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# ─── Node.js (Dashboard, Docs, SDK) ─────────────────────────────────
node_modules/
.next/
out/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Android (Gateway) ──────────────────────────────────────────────
*.apk
*.aab
.gradle/
local.properties
kadryza-gateway/build/
kadryza-gateway/app/build/
*.iml

# ─── Environment ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ─── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Vercel ──────────────────────────────────────────────────────────
.vercel

# ─── sqlc generated (optionally track this) ──────────────────────────
# internal/db/sqlc/

# ─── Temporary files ─────────────────────────────────────────────────
tmp/
