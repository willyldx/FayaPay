# =============================================================================
# Kadryza Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Serveur
PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://kadryza:password@localhost:5432/kadryza?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRY=24h

# Gateway WebSocket
GATEWAY_TOKEN_SECRET=change_me_to_another_long_random_secret

# Webhook
WEBHOOK_TIMEOUT_SECONDS=10

# Transaction
TRANSACTION_TIMEOUT_MINUTES=5

# CORS — comma-separated list of allowed origins
# In production, set to your actual dashboard URL(s)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
